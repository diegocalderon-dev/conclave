{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RunManifest",
  "type": "object",
  "required": ["runId", "task", "depth", "autonomy", "transcriptRetention", "adapters", "activeLanes", "startedAt", "artifactRoot", "phases"],
  "properties": {
    "runId": { "type": "string" },
    "task": { "type": "string" },
    "target": { "type": "string" },
    "depth": { "type": "string", "enum": ["low", "medium", "high", "exhaustive"] },
    "autonomy": { "type": "string", "enum": ["supervised", "autonomous"] },
    "transcriptRetention": { "type": "string", "enum": ["none", "summary", "full"] },
    "adapters": { "type": "array", "items": { "type": "string" } },
    "activeLanes": { "type": "array", "items": { "type": "string" } },
    "startedAt": { "type": "string", "format": "date-time" },
    "completedAt": { "type": "string", "format": "date-time" },
    "artifactRoot": { "type": "string" },
    "phases": { "type": "array" }
  }
}
