# Conclave configuration
# Copy to conclave.toml and adjust for your environment.

# Where run artifacts are stored. Defaults to ~/.conclave/artifacts
# artifact_root = "~/.conclave/artifacts"

# Default depth profile: low | medium | high | exhaustive
depth = "medium"

# Default autonomy mode: supervised | autonomous
autonomy = "supervised"

# Transcript retention: none | summary | full
transcript_retention = "summary"

[adapters]
# Adapter-specific overrides. Omit to use auto-detection.

[adapters.claude]
# command = "claude"
# model = "sonnet"

[adapters.codex]
# command = "codex"
# model = "o3"

[lanes]
# Lane policy defaults
# enabled = ["independent-draft", "atomic-claim", "issue-debate", "hybrid-edit", "contrarian"]
# max_parallel = 2

[limits]
# max_rounds = 10
# stagnation_threshold = 2
# max_claims = 50
