{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Issue",
  "type": "object",
  "required": ["id", "title", "description", "state", "raisedBy", "round"],
  "properties": {
    "id": { "type": "string", "pattern": "^issue-" },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "state": {
      "type": "string",
      "enum": ["open", "narrowed", "hybrid_proposed", "resolved", "irreducible_disagreement"]
    },
    "raisedBy": { "type": "string" },
    "round": { "type": "integer", "minimum": 1 },
    "transitions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to", "reason", "round", "actor"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "reason": { "type": "string" },
          "round": { "type": "integer" },
          "actor": { "type": "string" }
        }
      }
    },
    "relatedClaims": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
