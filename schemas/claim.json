{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Claim",
  "type": "object",
  "required": ["id", "text", "status", "source", "round"],
  "properties": {
    "id": { "type": "string", "pattern": "^claim-" },
    "text": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["proposed", "accepted", "rejected", "modified", "merged", "withdrawn"]
    },
    "source": { "type": "string" },
    "round": { "type": "integer", "minimum": 1 },
    "evidence": {
      "type": "array",
      "items": { "type": "string" }
    },
    "modifiedFrom": { "type": "string" }
  }
}
