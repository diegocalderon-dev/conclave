# Conclave configuration
# Place as ./conclave.toml (project) or ~/.conclave/config.toml (user)

artifact_root = "~/.conclave/artifacts"
timeout = 300        # seconds, per adapter invocation
max_rounds = 3       # cross-review rounds (hard limit)
allow_writes = false  # read-only by default

[adapters.claude]
command = "claude"
model = ""  # empty = adapter default

[adapters.codex]
command = "codex"
model = ""
